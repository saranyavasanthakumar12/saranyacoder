class Main {
    public static void main(String[] args) {
        System.out.println(evenlyDivides(23));
    }
    static int evenlyDivides(int n) {
        int num=n;
        int result=0;
        while(num>0){
            int digit=num%10;
            if(digit==0)continue;
            if(n%digit==0){
                result+=1;
            }
            num=num/10;
        }
        return result;
    }
}
