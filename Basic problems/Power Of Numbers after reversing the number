class Solution {
    public int reverseExponentiation(int n) {
        if(n>10 || n<1)return -1;
        int num=n;
        int result=0;
        while(num>0){
        int digit=num%10;
        if(digit==0){
            num/=10;
            continue;
        }
        result=result*10+digit;
        num/=10;
        }
        int ans=(int)Math.pow(n,result);
        return ans;
    }
}
