class Main {
    public static void main(String[] args) {
        int n=325345;
        int result=0;
        while(n>0){
            int digit=n%10;
            if(digit==0){
                n/=10;
                continue;
            }
            result=result*10+digit;
            n/=10;
        }
        System.out.println(result);
}
}
