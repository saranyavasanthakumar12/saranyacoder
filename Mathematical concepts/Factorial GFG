class Main {
    
    static int factorial(int n, int fact) {
        if (n == 0 || n == 1) {
            return fact;
        }
        return factorial(n - 1, fact * n);
    }

    public static void main(String[] args) {
        int n = 5;
        int fact = 1;
        System.out.println(factorial(n, fact));
    }
}
