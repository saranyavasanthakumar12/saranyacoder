class Solution {
    static boolean isPrime(int n) {
        if(n==1){
            return false;
        }
        int count=0;
        for(int i=2;i<=n;i++){
        if(n%i==0){
            count++;
        }
        }
        if(count==1){
        return true;
        }
        return false;
    }
}
